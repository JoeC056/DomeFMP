  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'You answer the knock on the door to a group, headed by a tall, confident
    man donned in a well-fitted suit, and a much shorter, scruffy and agitated man
    next to him.

    They are familiar faces, even though, you have never truely
    met face to face.

    The spy abruptly signals you to follow, and begins marching
    to what you can only assume to be the safe room.

    The journey is short, and
    you go unnoticed, with adequate room for everyone to take a seat and rest.

    In
    the room, there is silence. No movement, no words spoken, not even eye contact
    is made.

    Even Nikolai, despite his seemingly confident, hate-ridden anticipation
    when he informed you of the raid, utters not a word. Instead, he seems afraid,
    but, not for himself.

    All the while, the fear of the fate on your daughter
    weighs upon your mind and body, as you struggle to stop the shaking, the heavy
    breathing, the fear.

    All of which is only escalated by the sound of the
    beginning operation, the air is polluted with sounds of gunshots, explosions,
    sound you have never heard before, not even knowing what may be creating them.

    These
    sound eventually halt in what seems like an everlasting silence, before being
    met with cheers of excitement.

    With your peers, you rush out the room, the
    sight of the safety of everyones friends and family only creating more who are
    celebrating.

    But, among them, was not Romina.

    You rush to what you
    can only assume is the headquarters, desperate to find what mattered to you most
    in this world.

    Among all the bodies, all the dead cultists, those who would
    dare threaten take her, from you, you find her.

    Slouched, motionless, lifeless.

    The
    cost of the life''s of all your peers, all your friends, all of their families,
    was the only thing is this world you would live for.

    And for her, who lived
    for others, would that not be what she would have chose?'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
