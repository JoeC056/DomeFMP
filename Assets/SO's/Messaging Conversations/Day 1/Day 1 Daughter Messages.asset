  m_Name: Day 1 Daughter Messages
  m_EditorClassIdentifier: 
  personSpokenTo: {fileID: 11400000, guid: 08a894b9b170bd4408c3738b6b563b07, type: 2}
  delayBetweenMessages: 1
  lines:
  - "Hi Dad, I\u2019m assuming you saw that radio transmission and know what\u2019s
    going on but, I can\u2019t leave the place I\u2019m staying at for my placements
    until I\u2019m evacuated, which I\u2019m apparently quite low priority on\u2026."
  - "What\u2019s happening with you? Are you going today, tomorrow, later, will I
    see you soon?"
  bridgeAfterMessages: 1
  bridgeResponse1: "I\u2019m being stationed on border control for evacuating citizens,
    but remotely. Need to look out for symptoms, check to allow people through, all
    stuff like that."
  bridgeResponse2: 
