  m_Script: {fileID: 11500000, guid: 46e03a19f8e5e124dad137a0f14696cc, type: 3}
  m_Name: D2FR Dialogue
  m_EditorClassIdentifier: 
  delayBetweenCharacters: 0.035
  delayBetweenMessages: 1
  dialogueHidesSubmit: 0
  lines:
  - You are (CHARACTER NAME) Yes?
  - 'Father: Umm yes, why is that?'
  - "Recruiter: I am a member of a faction of people who are suspicious of the government
    and their actions, comprised of many like you, and our fellow member and founder
    you would have met yesterday, that feel they remember the events of the government
    \u201Csaving us\u201D from the other government differently to what we were taught."
  - 'Recruiter: We need your help, whilst many of us still have access to our computers,
    outside of messaging the functionality is missing. '
  - 'Recruiter: We believe the government is planning something greater with their
    actions, something that will affect everyone within the dome, but exactly how
    we do not understand.'
  - 'Recruiter: Only you and your coworkers have access to the internet, and you
    are the only one who is old enough to remember the events enough to understand
    our motives.'
  - 'Recruiter: Would you be willing to help us?'
  - 'Father: Sure'
  - 'Recruiter: Thank you, we will be in touch'
  bridgeAfterDialogue: 0
  clearTranscriptUponBridging: 0
