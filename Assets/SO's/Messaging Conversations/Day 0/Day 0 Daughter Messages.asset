  m_Name: Day 0 Daughter Messages
  m_EditorClassIdentifier: 
  personSpokenTo: {fileID: 11400000, guid: 08a894b9b170bd4408c3738b6b563b07, type: 2}
  delayBetweenMessages: 2
  lines:
  - "Hi Dad!!! Sorry I couldn\u2019t make it home today, I need to stay away for
    my university placements for the day. "
  - "On the bright side, I\u2019ve been able to learn so much working at the orphanage
    and being able to speak to everyone else working there, it\u2019s the best! "
  - But how was your day at work?
  bridgeAfterMessages: 1
  bridgeResponse1: "Uneventful as unusual, but it\u2019s great to hear you\u2019re
    still trying your best with university,  I\u2019m always proud seeing how far
    you\u2019ve come."
  bridgeResponse2: 
